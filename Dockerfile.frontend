FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies from package-lock.json for reproducible builds
RUN npm ci

# Copy application
COPY frontend/ .

# Build application
RUN npm run build

# Expose port
EXPOSE 3000

# Serve application on the Docker-exposed interface
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0"]
